[Unit]
Description=Resume Auto-Apply Service
After=network.target

[Service]
Type=oneshot
User=jclee
WorkingDirectory=/home/jclee/dev/resume/apps/job-server
ExecStart=/home/jclee/dev/resume/apps/job-server/scripts/run-auto-apply.sh
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target