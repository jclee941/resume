    {
      "parameters": {
        "jsCode": "// JobKorea Error Handler with exponential backoff retry state tracking\nconst item = $input.first();\nconst retryCount = (item.json.retryCount || 0);\nconst maxRetries = 3;\nconst event = item.json.body?.event || 'unknown';\nconst error = item.json.body?.error || 'Unknown error';\nconst timestamp = new Date().toISOString();\n\nconsole.error(`[JobKorea Error Handler] event=${event} error=${error} retry=${retryCount}/${maxRetries} time=${timestamp}`);\n\nif (retryCount < maxRetries) {\n  return [{\n    json: {\n      ...item.json,\n      retryCount: retryCount + 1,\n      willRetry: true,\n      retryAfterMs: Math.pow(2, retryCount) * 1000,\n      lastError: error,\n      platform: 'jobkorea'\n    }\n  }];\n}\n\nreturn [{\n  json: {\n    ...item.json,\n    retryCount,\n    willRetry: false,\n    finalError: true,\n    loggedAt: timestamp,\n    platform: 'jobkorea',\n    summary: `JobKorea automation failed after ${maxRetries} retries: ${error}`\n  }\n}];"
      },
