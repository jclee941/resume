    {
      "parameters": {
        "command": "={{ 'BRANCH=' + JSON.stringify($json.branchName) + ' && git restore apps/portfolio/worker.js apps/portfolio/data*.json && git checkout -b \"$BRANCH\" && git add package.json package-lock.json && git commit -m \"chore: auto-update deps [automated]\" && git push \"https://oauth2:' + $env.GITLAB_TOKEN + '@' + $env.GITLAB_HOST + '/' + $env.CI_PROJECT_PATH + '.git\" \"$BRANCH\"' }}"
      },
      "id": "git-branch-commit-push-deps",
