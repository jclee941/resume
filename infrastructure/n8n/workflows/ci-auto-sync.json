      "parameters": {
        "method": "POST",
        "url": "={{ $env.GITLAB_URL + '/api/v4/projects/' + $env.CI_PROJECT_ID + '/merge_requests' }}",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "PRIVATE-TOKEN",
              "value": "={{ $env.GITLAB_TOKEN }}"
