        "jsonBody": "={{ JSON.stringify({ source_branch: $('gen-branch-name-deps').item.json.branchName, target_branch: 'master', title: 'chore: auto-update deps', description: 'Automated weekly dependency update\\n\\n- [ ] Review dependency changes\\n- [ ] Verify no breaking changes', labels: 'dependencies,auto-merge', remove_source_branch: true }) }}",
        "options": {}
      },
      "id": "create-mr-deps",
      "name": "create-mr-deps",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.3,
      "position": [1650, 600],
