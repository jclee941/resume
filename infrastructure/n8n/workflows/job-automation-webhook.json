        "additionalOptions": {
          "parse_mode": "Markdown",
          "disable_web_page_preview": true
        }
      },
      "id": "telegram-success",
      "name": "Telegram: Apply Success",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1,
      "position": [650, 150],
      "credentials": {
        "telegramApi": {
          "id": "telegram-credentials",
          "name": "Telegram Bot"
        }
      }
    },
    {
      "parameters": {
